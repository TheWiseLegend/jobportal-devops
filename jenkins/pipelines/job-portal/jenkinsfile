@Library('jobportal-shared-lib') _

pipeline {
    agent any

    environment {
        IMAGE_NAME = "amrthedev/jobportal"
        IMAGE_TAG  = "${BUILD_NUMBER}"
        FULL_IMAGE = "${IMAGE_NAME}:${IMAGE_TAG}"
    }

    stages {

        stage('Checkout') {
            steps {
                // Clone backend source into a subdirectory called 'jobportal'
                dir('jobportal') {
                    git url: 'https://github.com/TheWiseLegend/jobportal.git',
                        branch: 'main'
                }

                // Clone devops repo (contains our Dockerfile) into 'jobportal-devops'
                dir('jobportal-devops') {
                    git url: 'https://github.com/TheWiseLegend/jobportal-devops.git',
                        branch: 'main'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                // Calls vars/buildDockerImage.groovy from jobportal-shared-lib
                // Args: full image name, path to Dockerfile, path to build context
                buildDockerImage(
                    "${FULL_IMAGE}",
                    "${WORKSPACE}/jobportal-devops/infrastructure/docker/Dockerfile",
                    "${WORKSPACE}/jobportal"
                )
            }
        }

        stage('Push to Docker Hub') {
            steps {
                // Calls vars/pushToRegistry.groovy from jobportal-shared-lib
                // Args: full image name, Jenkins credential ID
                pushToRegistry("${FULL_IMAGE}", 'dockerhub-credentials')
            }
        }
    }

    post {
        success {
            echo "Image ${FULL_IMAGE} built and pushed successfully"
        }
        failure {
            echo "Pipeline failed — check logs above"
        }
        always {
            cleanWs()
        }
    }
}
